ACCOUNT_GATEWAY_IMAGE=ghcr.io/onix-fun/account-gateway
ACCOUNT_SERVICE_IMAGE=ghcr.io/onix-fun/account-service
ACCOUNT_TAG=v1.0.0
ACCOUNT_GATEWAY_HTTP_PORT=8089

SPARROW_TRUSTED_BASE_DOMAIN=example.com
ACCOUNT_TRUSTED_PROXY_CIDRS=10.0.0.0/8
ACCOUNT_SWAGGER_UI_ENABLED=false
ACCOUNT_HSTS_HEADER=max-age=31536000; includeSubDomains
ACCOUNT_CSP=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://app.example.com wss://app.example.com; object-src 'none'; base-uri 'none'; frame-ancestors 'none'
ACCOUNT_LOGIN_RATE=5r/m
ACCOUNT_RECOVERY_RATE=3r/m
ACCOUNT_CONFIRMATION_RATE=10r/m
ACCOUNT_USERNAME_RATE=20r/m
ACCOUNT_SESSION_RATE=30r/m
ACCOUNT_AVATAR_RATE=10r/m

IDENTITY_COOKIE_DOMAIN=example.com
IDENTITY_ACCESS_TOKEN_EXP_MINUTES=15
IDENTITY_REFRESH_TOKEN_EXP_DAYS=30

ACCOUNT_POSTGRES_DB=account
ACCOUNT_POSTGRES_USER=account
ACCOUNT_POSTGRES_PASSWORD=replace-with-a-strong-password
ACCOUNT_REDIS_URL=redis://account-redis:6379

ACCOUNT_MINIO_ROOT_USER=account-minio
ACCOUNT_MINIO_ROOT_PASSWORD=replace-with-a-strong-password
IDENTITY_S3_PUBLIC_URL=https://account.example.com/api/avatars
IDENTITY_S3_BUCKET=avatars

IDENTITY_SMTP_HOST=smtp.example.com
IDENTITY_SMTP_PORT=587
IDENTITY_SMTP_USERNAME=apikey-or-user
IDENTITY_SMTP_PASSWORD=replace-with-smtp-password
IDENTITY_SMTP_FROM=no-reply@example.com

CENTRAL_OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com
