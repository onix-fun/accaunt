# App configuration
ACCOUNT_TRUSTED_BASE_DOMAIN=localhost

# Ports
ACCOUNT_GATEWAY_HTTP_PORT=8089
ACCOUNT_MINIO_API_PORT=9010
ACCOUNT_MINIO_CONSOLE_PORT=9011
ACCOUNT_MAIL_SMTP_PORT=1026
ACCOUNT_MAIL_UI_PORT=8026

# Database
POSTGRES_DB=account
POSTGRES_USER=account
POSTGRES_PASSWORD=account
IDENTITY_DATABASE_JDBC_URL=jdbc:postgresql://account-postgres:5432/account

# Rates
ACCOUNT_LOGIN_RATE=5r/m
ACCOUNT_RECOVERY_RATE=3r/m
ACCOUNT_CONFIRMATION_RATE=10r/m
ACCOUNT_USERNAME_RATE=20r/m
ACCOUNT_SESSION_RATE=30r/m
ACCOUNT_AVATAR_RATE=10r/m
